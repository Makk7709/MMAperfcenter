# ============================================================================
# KOREV Performance Center — Environment variables template
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the real values for your environment.
# `.env` is gitignored and MUST NOT be committed.
#
# All variables prefixed with VITE_ are exposed to the client bundle and must
# therefore only contain publishable (anon) values. Server-side secrets are
# configured separately in the Supabase dashboard (Edge Functions secrets).
# ============================================================================

# --- Supabase (client) ------------------------------------------------------
# Public project URL of your Supabase project.
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"

# Public anon JWT (publishable, RLS-enforced). Never put service role here.
VITE_SUPABASE_PUBLISHABLE_KEY="<your-supabase-anon-key>"

# Project ID convenience variable (optional, used by some tooling).
VITE_SUPABASE_PROJECT_ID="<your-project-ref>"

# ============================================================================
# Server-side secrets (NEVER add them to this file — they live in Supabase
# Edge Functions secrets only):
#   - SUPABASE_SERVICE_ROLE_KEY   (Supabase admin key, server-side only)
#   - STRIPE_SECRET_KEY           (Stripe sk_live_... / sk_test_...)
#   - STRIPE_WEBHOOK_SECRET       (Stripe webhook signing secret, whsec_...)
#   - AI_GATEWAY_API_KEY          (AI gateway bearer token)
#   - AI_GATEWAY_URL              (optional, overrides default gateway URL)
# ============================================================================
